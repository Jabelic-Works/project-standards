{
  "name": "@jabelic/standards-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "standards": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@jabelic/standards-core": "workspace:*",
    "citty": "^0.2.1",
    "consola": "^3.4.2"
  }
}
