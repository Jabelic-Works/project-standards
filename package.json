{
  "name": "project-standards",
  "version": "0.1.0",
  "private": true,
  "description": "CLI and shared standards for bootstrapping repositories with Jabelic defaults.",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r clean",
    "dev:cli": "pnpm --filter @jabelic/standards-cli dev"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
